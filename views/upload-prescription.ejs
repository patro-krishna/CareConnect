  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
  <div class="container">

    <a class="navbar-brand fw-bold" href="/">
      CareConnect
    </a>

    <button class="navbar-toggler" type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navMenu">

      <span class="navbar-toggler-icon"></span>

    </button>

    <div class="collapse navbar-collapse" id="navMenu">

      <ul class="navbar-nav ms-auto">

        <li class="nav-item">
          <a class="nav-link" href="/dashboard">Dashboard</a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/doctors">Doctors</a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/appointments">Appointments</a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/prescriptions">Prescriptions</a>
        </li>

        <li class="nav-item">
          <a class="nav-link active" href="/upload-prescription">Upload</a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/logout">Logout</a>
        </li>
        <li class="nav-item">
  <button id="themeToggle" class="btn btn-sm btn-light ms-lg-3 mt-2 mt-lg-0">
    🌙
  </button>
</li>

      </ul>

    </div>

  </div>
</nav>

<section class="page-header py-5">

  <div class="container">

    <h1 class="fw-bold text-primary">
      Upload Prescription
    </h1>

    <p class="lead">
      Upload and store your prescriptions securely.
    </p>

  </div>

</section>

<div class="container py-5">

  <div class="row g-4">

    <div class="col-lg-8">

      <div class="card shadow border-0 upload-card">

        <div class="card-body p-4">

          <h3 class="mb-4">
            Upload Medical Prescription
          </h3>

          <% if(error){ %>

            <div class="alert alert-danger">
              <%= error %>
            </div>

          <% } %>

          <% if(success){ %>

            <div class="alert alert-success">
              <%= success %>
            </div>

          <% } %>

<form action="/upload-prescription" method="POST" enctype="multipart/form-data" id="prescriptionForm">

            <div class="mb-3">

              <label class="form-label">
                Prescription Title
              </label>

              <input type="text" name="title" id="prescriptionTitle" class="form-control" placeholder="Enter Prescription Title" required>

<input type="text" name="doctorName" id="prescriptionDoctor" class="form-control" placeholder="Doctor Name" required>

<input type="file" name="prescriptionFile" id="prescriptionFile" class="form-control" accept=".pdf,.jpg,.jpeg,.png" required>

<p id="prescriptionError" class="client-error"></p>

            <button
              type="submit"
              class="btn btn-primary btn-lg">

              Upload Prescription

            </button>

          </form>

        </div>

      </div>

    </div>

    <div class="col-lg-4">

      <div class="card shadow border-0 h-100">

        <div class="card-body">

          <h4 class="mb-4">
            Upload Guidelines
          </h4>

          <ul>

            <li>PDF files allowed</li>

            <li>JPG, JPEG, PNG supported</li>

            <li>Maximum size: 5 MB</li>

            <li>Use clear prescription images</li>

            <li>Verify doctor details before upload</li>

          </ul>

          <hr>

          <h5>
            Benefits
          </h5>

          <p>
            Store prescriptions digitally and access them anytime from your account.
          </p>

          <div class="text-center mt-4">

            <h1>📄</h1>

            <p>
              Secure Medical Record Storage
            </p>

          </div>

        </div>

      </div>

    </div>

  </div>

</div>

<section class="py-5 bg-light">

  <div class="container text-center">

    <h2 class="fw-bold">
      Why Upload Prescriptions?
    </h2>

    <p class="lead mt-3">

      Easily access previous prescriptions,
      track treatment history and maintain
      digital healthcare records.

    </p>

  </div>

</section>

<footer class="footer py-5">
  <div class="container">

    <div class="row g-4">

      <div class="col-lg-4">
        <h4 class="fw-bold mb-3">🏥 CareConnect</h4>

        <p>
          Smart Healthcare Platform for online appointments,
          prescription management, doctor discovery and
          seamless patient care.
        </p>
      </div>

      <div class="col-lg-2">
        <h5 class="mb-3">Quick Links</h5>

        <ul class="list-unstyled">
          <li><a href="/" class="footer-link">Home</a></li>
          <li><a href="/doctors" class="footer-link">Doctors</a></li>
          <li><a href="/dashboard" class="footer-link">Dashboard</a></li>
          <li><a href="/appointments" class="footer-link">Appointments</a></li>
        </ul>
      </div>

      <div class="col-lg-3">
        <h5 class="mb-3">Company</h5>

        <ul class="list-unstyled">
          <li><a href="/about" class="footer-link">About Us</a></li>
          <li><a href="/privacy" class="footer-link">Privacy Policy</a></li>
          <li><a href="/terms" class="footer-link">Terms & Conditions</a></li>
        </ul>
      </div>

      <div class="col-lg-3">
        <h5 class="mb-3">Contact</h5>

        <p class="mb-2">📧 support@careconnect.com</p>
        <p class="mb-2">📞 +91 9876543210</p>
        <p>📍 Bhubaneswar, Odisha, India</p>
      </div>

    </div>

    <hr class="my-4">

    <div class="text-center">
      <p class="mb-0">
        © 2026 CareConnect | Smart Healthcare Platform | All Rights Reserved
      </p>
    </div>

  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>
</body>
</html>