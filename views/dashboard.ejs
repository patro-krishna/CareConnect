<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Patient Dashboard</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">CareConnect</a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navMenu">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
        <li class="nav-item"><a class="nav-link active" href="/dashboard">Dashboard</a></li>
        <li class="nav-item"><a class="nav-link" href="/doctors">Doctors</a></li>
        <li class="nav-item"><a class="nav-link" href="/appointments">Appointments</a></li>
        <li class="nav-item"><a class="nav-link" href="/prescriptions">Prescriptions</a></li>
        <li class="nav-item"><a class="nav-link" href="/upload-prescription">Upload</a></li>
        <li class="nav-item"><a class="nav-link" href="/logout">Logout</a></li>
        <li class="nav-item">
  <button id="themeToggle" class="btn btn-sm btn-light ms-lg-3 mt-2 mt-lg-0">
    🌙
  </button>
</li>
      </ul>
    </div>
  </div>
</nav>

<section class="page-header">
  <div class="container py-5">
    <h1 class="fw-bold text-primary">Welcome, <%= user.name %> 👋</h1>
    <p class="lead mb-0">Manage your appointments, prescriptions and healthcare records from one place.</p>
  </div>
</section>

<section class="py-5">
  <div class="container">

    <div class="alert alert-primary shadow-sm mb-5">
      <h4 class="mb-2">Welcome Back, <%= user.name %></h4>
      <p class="mb-0">
        Use this dashboard to book appointments, track appointment status and manage prescription records.
      </p>
    </div>

    <div class="row g-4 mb-5">
      <div class="col-md-4">
        <div class="card shadow h-100 dashboard-card">
          <div class="card-body">
            <h4>Book Appointment</h4>
            <p>Find available doctors and book your appointment.</p>
            <a href="/doctors" class="btn btn-primary">View Doctors</a>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card shadow h-100 dashboard-card">
          <div class="card-body">
            <h4>Appointment History</h4>
            <p>View previous, upcoming and cancelled appointments.</p>
            <a href="/appointments" class="btn btn-primary">View Appointments</a>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card shadow h-100 dashboard-card">
          <div class="card-body">
            <h4>Prescription Records</h4>
            <p>Upload and manage your prescription files.</p>
            <a href="/upload-prescription" class="btn btn-primary">Upload Prescription</a>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-md-6">
        <div class="info-panel shadow">
          <h4>Patient Details</h4>
          <p><b>Name:</b> <%= user.name %></p>
          <p><b>Email:</b> <%= user.email %></p>
          <p><b>Account Type:</b> Patient</p>
          <p><b>Status:</b> Active</p>
        </div>
      </div>

      <div class="col-md-6">
        <div class="info-panel shadow">
          <h4>Quick Actions</h4>
          <a href="/doctors" class="btn btn-outline-primary me-2 mb-2">Doctors</a>
          <a href="/appointments" class="btn btn-outline-primary me-2 mb-2">Appointments</a>
          <a href="/prescriptions" class="btn btn-outline-primary me-2 mb-2">Prescriptions</a>
          <a href="/upload-prescription" class="btn btn-outline-primary mb-2">Upload</a>
          <a href="/medicine-search" class="btn btn-outline-primary me-2 mb-2">Medicine API</a>
        </div>
      </div>
    </div>

    <div class="row mt-5">
      <div class="col-md-12">
        <div class="info-panel shadow">
          <h4>Health Tips</h4>
          <ul class="mb-0">
            <li>Drink enough water every day.</li>
            <li>Exercise or walk for at least 30 minutes daily.</li>
            <li>Schedule regular health checkups.</li>
            <li>Follow your prescribed medicines properly.</li>
            <li>Keep your prescription records safe and updated.</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="row mt-4 g-4">
      <div class="col-md-4">
        <div class="card shadow dashboard-card h-100">
          <div class="card-body text-center">
            <h3>🩺</h3>
            <h5>Doctor Management</h5>
            <p>Browse and connect with experienced doctors.</p>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card shadow dashboard-card h-100">
          <div class="card-body text-center">
            <h3>📅</h3>
            <h5>Appointment Tracking</h5>
            <p>Track appointment status and history easily.</p>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card shadow dashboard-card h-100">
          <div class="card-body text-center">
            <h3>📄</h3>
            <h5>Prescription Storage</h5>
            <p>Securely store and access prescriptions online.</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<section class="py-5 bg-light">
  <div class="container text-center">
    <h2 class="mb-4">Emergency Support</h2>
    <h4 class="text-danger">📞 Emergency Helpline: +91 9876543210</h4>
    <p>Available 24 Hours a Day, 7 Days a Week</p>
  </div>
</section>

<footer class="footer py-5">
  <div class="container">

    <div class="row g-4">

      <div class="col-lg-4">
        <h4 class="fw-bold mb-3">🏥 CareConnect</h4>

        <p>
          Smart Healthcare Platform for online appointments,
          prescription management, doctor discovery and
          seamless patient care.
        </p>
      </div>

      <div class="col-lg-2">
        <h5 class="mb-3">Quick Links</h5>

        <ul class="list-unstyled">
          <li><a href="/" class="footer-link">Home</a></li>
          <li><a href="/doctors" class="footer-link">Doctors</a></li>
          <li><a href="/dashboard" class="footer-link">Dashboard</a></li>
          <li><a href="/appointments" class="footer-link">Appointments</a></li>
        </ul>
      </div>

      <div class="col-lg-3">
        <h5 class="mb-3">Company</h5>

        <ul class="list-unstyled">
          <li><a href="/about" class="footer-link">About Us</a></li>
          <li><a href="/privacy" class="footer-link">Privacy Policy</a></li>
          <li><a href="/terms" class="footer-link">Terms & Conditions</a></li>
        </ul>
      </div>

      <div class="col-lg-3">
        <h5 class="mb-3">Contact</h5>

        <p class="mb-2">📧 support@careconnect.com</p>
        <p class="mb-2">📞 +91 9876543210</p>
        <p>📍 Bhubaneswar, Odisha, India</p>
      </div>

    </div>

    <hr class="my-4">

    <div class="text-center">
      <p class="mb-0">
        © 2026 CareConnect | Smart Healthcare Platform | All Rights Reserved
      </p>
    </div>

  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>
</body>
</html>