<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Prescriptions</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">CareConnect</a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navMenu">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link" href="/dashboard">Dashboard</a></li>
        <li class="nav-item"><a class="nav-link" href="/doctors">Doctors</a></li>
        <li class="nav-item"><a class="nav-link" href="/appointments">Appointments</a></li>
        <li class="nav-item"><a class="nav-link active" href="/prescriptions">Prescriptions</a></li>
        <li class="nav-item"><a class="nav-link" href="/upload-prescription">Upload</a></li>
        <li class="nav-item"><a class="nav-link" href="/logout">Logout</a></li>
        <li class="nav-item">
  <button id="themeToggle" class="btn btn-sm btn-light ms-lg-3 mt-2 mt-lg-0">
    🌙
  </button>
</li>
      </ul>
    </div>
  </div>
</nav>

<section class="page-header py-5">
  <div class="container">
    <h1 class="fw-bold text-primary">My Prescriptions</h1>
    <p class="lead">
      View, manage and access all your uploaded prescription records.
    </p>
  </div>
</section>

<section class="py-5">
  <div class="container">

    <div class="alert alert-info shadow-sm mb-4">
      <h5>Prescription Record Information</h5>
      <p class="mb-0">
        Uploaded prescriptions are stored securely and can be viewed anytime.
        Supported formats include PDF, JPG, JPEG and PNG.
      </p>
    </div>

    <div class="row g-4 mb-5">

      <div class="col-md-4">
        <div class="card shadow border-0 text-center h-100">
          <div class="card-body">
            <h3>📄</h3>
            <h5>Digital Records</h5>
            <p>Keep your medical prescriptions safe online.</p>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card shadow border-0 text-center h-100">
          <div class="card-body">
            <h3>🔍</h3>
            <h5>Easy Access</h5>
            <p>View prescriptions whenever needed.</p>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card shadow border-0 text-center h-100">
          <div class="card-body">
            <h3>🔐</h3>
            <h5>Secure Storage</h5>
            <p>Prescription details are linked to your account.</p>
          </div>
        </div>
      </div>

    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="fw-bold">Uploaded Prescriptions</h2>
      <a href="/upload-prescription" class="btn btn-primary">Upload New</a>
    </div>

    <div class="row g-4">

      <% if (prescriptions.length === 0) { %>
        <div class="col-12">
          <div class="alert alert-warning">
            No prescriptions uploaded yet.
          </div>
        </div>
      <% } %>

      <% prescriptions.forEach(item => { %>
        <div class="col-md-6 col-lg-4">
          <div class="card shadow border-0 h-100 prescription-card">
            <div class="card-body">

              <div class="prescription-icon mb-3">
                📑
              </div>

              <h4 class="text-primary fw-bold">
                <%= item.title %>
              </h4>

              <p>
                <strong>Doctor:</strong>
                <%= item.doctorName %>
              </p>

              <p>
                <strong>Notes:</strong>
                <%= item.notes || "No notes added" %>
              </p>

              <p>
                <strong>Uploaded:</strong>
                <%= item.createdAt.toDateString() %>
              </p>

              <div class="d-flex gap-2">
                <a href="<%= item.filePath %>" target="_blank" class="btn btn-primary w-50">
                  View
                </a>

                <form action="/prescriptions/delete/<%= item._id %>" method="POST" class="w-50">
                  <button type="submit" class="btn btn-danger w-100">
                    Delete
                  </button>
                </form>
              </div>

            </div>
          </div>
        </div>
      <% }) %>

    </div>

  </div>
</section>

<section class="py-5 bg-light">
  <div class="container text-center">
    <h2 class="fw-bold mb-3">Prescription Safety Reminder</h2>
    <p class="lead">
      Always follow your doctor's advice and keep prescriptions updated for future consultations.
    </p>
  </div>
</section>

<footer class="footer py-5">
  <div class="container">

    <div class="row g-4">

      <div class="col-lg-4">
        <h4 class="fw-bold mb-3">🏥 CareConnect</h4>

        <p>
          Smart Healthcare Platform for online appointments,
          prescription management, doctor discovery and
          seamless patient care.
        </p>
      </div>

      <div class="col-lg-2">
        <h5 class="mb-3">Quick Links</h5>

        <ul class="list-unstyled">
          <li><a href="/" class="footer-link">Home</a></li>
          <li><a href="/doctors" class="footer-link">Doctors</a></li>
          <li><a href="/dashboard" class="footer-link">Dashboard</a></li>
          <li><a href="/appointments" class="footer-link">Appointments</a></li>
        </ul>
      </div>

      <div class="col-lg-3">
        <h5 class="mb-3">Company</h5>

        <ul class="list-unstyled">
          <li><a href="/about" class="footer-link">About Us</a></li>
          <li><a href="/privacy" class="footer-link">Privacy Policy</a></li>
          <li><a href="/terms" class="footer-link">Terms & Conditions</a></li>
        </ul>
      </div>

      <div class="col-lg-3">
        <h5 class="mb-3">Contact</h5>

        <p class="mb-2">📧 support@careconnect.com</p>
        <p class="mb-2">📞 +91 9876543210</p>
        <p>📍 Bhubaneswar, Odisha, India</p>
      </div>

    </div>

    <hr class="my-4">

    <div class="text-center">
      <p class="mb-0">
        © 2026 CareConnect | Smart Healthcare Platform | All Rights Reserved
      </p>
    </div>

  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>
</body>
</html>