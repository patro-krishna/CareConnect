<!-- Header -->

<section class="page-header py-5 text-center">
  <div class="container">
    <h1 class="fw-bold text-primary">About CareConnect</h1>
    <p class="lead">
      Smart Healthcare Platform Connecting Patients, Doctors & Technology.
    </p>
  </div>
</section>

<!-- About Content -->

<section class="py-5">
  <div class="container">


<div class="card shadow border-0">
  <div class="card-body p-5">

    <h2 class="text-primary mb-4">Who We Are</h2>

    <p>
      CareConnect is a modern healthcare management platform that helps
      patients book appointments, manage prescriptions and connect with
      healthcare professionals digitally.
    </p>

    <p>
      Our platform simplifies healthcare management by providing a secure,
      user-friendly and responsive system for patients and administrators.
    </p>

    <hr class="my-4">

    <h2 class="text-primary mb-4">Our Mission</h2>

    <p>
      To improve healthcare accessibility and provide a seamless digital
      experience for patients, doctors and healthcare institutions.
    </p>

    <hr class="my-4">

    <h2 class="text-primary mb-4">Our Services</h2>

    <div class="row g-4">

      <div class="col-md-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body text-center">
            <h4>👨‍⚕️ Doctor Discovery</h4>
            <p>Browse doctors based on specialization and experience.</p>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body text-center">
            <h4>📅 Appointment Booking</h4>
            <p>Book appointments online without waiting in queues.</p>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body text-center">
            <h4>📄 Prescription Management</h4>
            <p>Upload and securely manage prescriptions online.</p>
          </div>
        </div>
      </div>

    </div>

    <hr class="my-5">

    <h2 class="text-primary mb-4">Why Choose CareConnect?</h2>

    <ul>
      <li>Fast & Secure Appointment Booking</li>
      <li>Modern Responsive User Interface</li>
      <li>Doctor Search & Management</li>
      <li>Prescription Upload System</li>
      <li>Medicine Information Search</li>
      <li>Secure Authentication & Data Storage</li>
    </ul>

  </div>
</div>


  </div>
