    <title>My Appointments</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">CareConnect</a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navMenu">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item">
          <a class="nav-link" href="/dashboard">Dashboard</a>
        </li>
        <li class="nav-item">
          <a class="nav-link active" href="/appointments">Appointments</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/doctors">Doctors</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/logout">Logout</a>
        </li>
        <li class="nav-item">
  <button id="themeToggle" class="btn btn-sm btn-light ms-lg-3 mt-2 mt-lg-0">
    🌙
  </button>
</li>
      </ul>
    </div>
  </div>
</nav>

<section class="page-header py-5">
    <div class="container">
        <h1 class="fw-bold text-primary">My Appointments</h1>
        <p class="lead">
            Track your booked appointments and appointment status.
        </p>
    </div>
</section>

<div class="container py-4">

    <!-- Info Banner -->

    <div class="alert alert-info shadow-sm">
        <h5>Appointment Information</h5>
        <p class="mb-0">
            You can view upcoming appointments, completed consultations,
            cancelled appointments and current appointment status here.
        </p>
    </div>

    <!-- Statistics Cards -->

    <div class="row g-4 my-4">

        <div class="col-md-4">
            <div class="card shadow border-0 text-center">
                <div class="card-body">
                    <h3>📅</h3>
                    <h5>Total Appointments</h5>
                    <p>Manage all appointment records.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow border-0 text-center">
                <div class="card-body">
                    <h3>🩺</h3>
                    <h5>Doctor Consultation</h5>
                    <p>Consult experienced specialists.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow border-0 text-center">
                <div class="card-body">
                    <h3>⚡</h3>
                    <h5>Status Tracking</h5>
                    <p>Track appointment approval instantly.</p>
                </div>
            </div>
        </div>

    </div>

    <!-- Appointment Cards -->

    <div class="row g-4">

        <% if (appointments.length === 0) { %>

            <div class="col-12">
                <div class="alert alert-warning">
                    No appointments found.
                </div>
            </div>

        <% } %>

        <% appointments.forEach(app => { %>

            <div class="col-lg-6">

                <div class="card shadow border-0 h-100">

                    <div class="card-body">

                        <h4 class="text-primary">
                            <%= app.doctorId ? app.doctorId.name : "Doctor Deleted" %>
                        </h4>

                        <p>
                            <strong>Specialization:</strong>
                            <%= app.doctorId ? app.doctorId.specialization : "N/A" %>
                        </p>

                        <p>
                            <strong>Date:</strong>
                            <%= app.appointmentDate %>
                        </p>

                        <p>
                            <strong>Time:</strong>
                            <%= app.appointmentTime %>
                        </p>

                        <p>
                            <strong>Reason:</strong>
                            <%= app.reason %>
                        </p>

                        <p>
                            <strong>Status:</strong>

                            <% if(app.status === "Pending"){ %>
                                <span class="badge bg-warning text-dark">
                                    Pending
                                </span>
                            <% } %>

                            <% if(app.status === "Approved"){ %>
                                <span class="badge bg-success">
                                    Approved
                                </span>
                            <% } %>

                            <% if(app.status === "Completed"){ %>
                                <span class="badge bg-primary">
                                    Completed
                                </span>
                            <% } %>

                            <% if(app.status === "Cancelled"){ %>
                                <span class="badge bg-danger">
                                    Cancelled
                                </span>
                            <% } %>

                        </p>

                        <% if(app.status !== "Cancelled"){ %>

                            <form
                                action="/appointments/cancel/<%= app._id %>"
                                method="POST">

                                <button
                                    type="submit"
                                    class="btn btn-danger">

                                    Cancel Appointment

                                </button>

                            </form>

                        <% } %>

                    </div>

                </div>

            </div>

        <% }) %>

    </div>

</div>

<!-- Health Reminder -->

<section class="bg-light py-5 mt-5">

    <div class="container text-center">

        <h2 class="mb-3">
            Health Reminder
        </h2>

        <p class="lead">
            Attend appointments on time and keep your prescriptions updated
            for better healthcare management.
        </p>

    </div>

</section>

