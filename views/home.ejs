<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CareConnect</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">CareConnect</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav ms-auto">

                <li class="nav-item">
                    <a class="nav-link active" href="/">Home</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/doctors">Doctors</a>
                </li>

                <% if (user) { %>
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">Dashboard</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/appointments">Appointments</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/prescriptions">Prescriptions</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/logout">Logout</a>
                    </li>
                <% } else { %>
                    <li class="nav-item">
                        <a class="nav-link" href="/login">Login</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/register">Register</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/admin/login">Admin</a>
                    </li>
                <% } %>

                <li class="nav-item">
                    <button id="themeToggle" class="btn btn-sm btn-light ms-lg-3 mt-2 mt-lg-0">
                        🌙
                    </button>
                </li>

            </ul>
        </div>
    </div>
</nav>

<section class="hero-section">
    <div class="container">
        <div class="row align-items-center min-vh-75">

            <div class="col-lg-7">
                <span class="badge bg-info text-dark mb-3">
                    Online Healthcare Platform
                </span>

                <h1 class="display-4 fw-bold text-primary">
                    Book Your Hospital Appointment Online
                </h1>

                <p class="lead my-4">
                    Find doctors, book appointments, upload prescriptions
                    and manage your healthcare records from anywhere.
                </p>

                <% if (user) { %>
                    <a href="/dashboard" class="btn btn-primary btn-lg me-2">
                        Go To Dashboard
                    </a>
                <% } else { %>
                    <a href="/register" class="btn btn-primary btn-lg me-2">
                        Get Started
                    </a>
                <% } %>

                <a href="/doctors" class="btn btn-outline-primary btn-lg">
                    View Doctors
                </a>
            </div>

            <div class="col-lg-5 mt-5 mt-lg-0">
                <div class="hero-card shadow-lg">
                    <h4 class="mb-4">Quick Services</h4>

                    <p>✔ Doctor Listing</p>
                    <p>✔ Online Appointment Booking</p>
                    <p>✔ Prescription Upload</p>
                    <p>✔ Appointment Tracking</p>
                    <p>✔ Admin Dashboard</p>
                </div>
            </div>

        </div>
    </div>
</section>

<section class="py-5 bg-primary text-white">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-3">
                <h1>100+</h1>
                <p>Doctors</p>
            </div>

            <div class="col-md-3">
                <h1>500+</h1>
                <p>Patients</p>
            </div>

            <div class="col-md-3">
                <h1>1000+</h1>
                <p>Appointments</p>
            </div>

            <div class="col-md-3">
                <h1>24/7</h1>
                <p>Support</p>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <h2 class="text-center fw-bold mb-5">Our Services</h2>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card service-card shadow-sm h-100">
                    <div class="card-body">
                        <h4>Doctor Listing</h4>
                        <p>Browse doctors by specialization, experience and consultation fees.</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card service-card shadow-sm h-100">
                    <div class="card-body">
                        <h4>Appointment Booking</h4>
                        <p>Schedule appointments online without waiting in queues.</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card service-card shadow-sm h-100">
                    <div class="card-body">
                        <h4>Prescription Upload</h4>
                        <p>Upload and store prescriptions securely in one place.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <h2 class="text-center fw-bold mb-5">Featured Doctors</h2>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card shadow h-100">
                    <div class="card-body text-center">
                        <h4>Dr. Amit Sharma</h4>
                        <p>Cardiologist</p>
                        <p>8 Years Experience</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow h-100">
                    <div class="card-body text-center">
                        <h4>Dr. Priya Singh</h4>
                        <p>Dermatologist</p>
                        <p>6 Years Experience</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow h-100">
                    <div class="card-body text-center">
                        <h4>Dr. Rahul Verma</h4>
                        <p>Neurologist</p>
                        <p>10 Years Experience</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <h2 class="text-center fw-bold mb-5">How It Works</h2>

        <div class="row text-center">
            <div class="col-md-4">
                <h1 class="text-primary">1</h1>
                <h5>Register</h5>
                <p>Create your patient account.</p>
            </div>

            <div class="col-md-4">
                <h1 class="text-primary">2</h1>
                <h5>Book Appointment</h5>
                <p>Select a doctor and book your slot.</p>
            </div>

            <div class="col-md-4">
                <h1 class="text-primary">3</h1>
                <h5>Upload Prescription</h5>
                <p>Store prescriptions securely online.</p>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <h2 class="text-center fw-bold mb-5">Patient Reviews</h2>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card shadow h-100">
                    <div class="card-body">
                        ⭐⭐⭐⭐⭐
                        <p class="mt-3">Very easy appointment booking process.</p>
                        <h6>- Abhinash Gupta</h6>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow h-100">
                    <div class="card-body">
                        ⭐⭐⭐⭐⭐
                        <p class="mt-3">Doctors were very professional and helpful.</p>
                        <h6>- Rahul Kumar</h6>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow h-100">
                    <div class="card-body">
                        ⭐⭐⭐⭐⭐
                        <p class="mt-3">Prescription upload feature is extremely useful.</p>
                        <h6>- Priya Sharma</h6>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <h2 class="text-center fw-bold mb-5">Contact Us</h2>

        <div class="row">
            <div class="col-md-6">
                <h5>Email</h5>
                <p>support@CareConnect.com</p>

                <h5>Phone</h5>
                <p>+91 9876543210</p>

                <h5>Address</h5>
                <p>Bhubaneswar, Odisha, India</p>
            </div>

            <div class="col-md-6">
                <div class="hero-card">
                    <h5>Hospital Timings</h5>
                    <p>Monday - Saturday</p>
                    <p>09:00 AM - 08:00 PM</p>
                    <p>Emergency Service Available 24/7</p>
                </div>
            </div>
        </div>
    </div>
</section>

<footer class="footer py-5">
  <div class="container">

    <div class="row g-4">

      <div class="col-lg-4">
        <h4 class="fw-bold mb-3">🏥 CareConnect</h4>

        <p>
          Smart Healthcare Platform for online appointments,
          prescription management, doctor discovery and
          seamless patient care.
        </p>
      </div>

      <div class="col-lg-2">
        <h5 class="mb-3">Quick Links</h5>

        <ul class="list-unstyled">
          <li><a href="/" class="footer-link">Home</a></li>
          <li><a href="/doctors" class="footer-link">Doctors</a></li>
          <li><a href="/dashboard" class="footer-link">Dashboard</a></li>
          <li><a href="/appointments" class="footer-link">Appointments</a></li>
        </ul>
      </div>

      <div class="col-lg-3">
        <h5 class="mb-3">Company</h5>

        <ul class="list-unstyled">
          <li><a href="/about" class="footer-link">About Us</a></li>
          <li><a href="/privacy" class="footer-link">Privacy Policy</a></li>
          <li><a href="/terms" class="footer-link">Terms & Conditions</a></li>
        </ul>
      </div>

      <div class="col-lg-3">
        <h5 class="mb-3">Contact</h5>

        <p class="mb-2">📧 support@careconnect.com</p>
        <p class="mb-2">📞 +91 9876543210</p>
        <p>📍 Bhubaneswar, Odisha, India</p>
      </div>

    </div>

    <hr class="my-4">

    <div class="text-center">
      <p class="mb-0">
        © 2026 CareConnect | Smart Healthcare Platform | All Rights Reserved
      </p>
    </div>

  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>
</body>
</html>