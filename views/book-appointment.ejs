<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Book Appointment</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">CareConnect</a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navMenu">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link" href="/dashboard">Dashboard</a></li>
        <li class="nav-item"><a class="nav-link" href="/doctors">Doctors</a></li>
        <li class="nav-item"><a class="nav-link" href="/appointments">Appointments</a></li>
        <li class="nav-item"><a class="nav-link" href="/prescriptions">Prescriptions</a></li>
        <li class="nav-item">
          <button id="themeToggle" class="btn btn-sm btn-light ms-lg-3 mt-2 mt-lg-0">🌙</button>
        </li>
        <li class="nav-item"><a class="nav-link" href="/logout">Logout</a></li>
      </ul>
    </div>
  </div>
</nav>

<section class="page-header py-5">
  <div class="container">
    <h1 class="fw-bold text-primary">Book Appointment</h1>
    <p class="lead">Choose your preferred date and time for consultation.</p>
  </div>
</section>

<section class="py-5">
  <div class="container">
    <div class="row g-4">

      <div class="col-lg-5">
        <div class="card shadow border-0 h-100">
          <div class="card-body text-center p-4">
            <img src="<%= doctor.image %>" class="doctor-img mb-3" alt="Doctor Image">

            <h3 class="fw-bold text-primary"><%= doctor.name %></h3>
            <span class="badge bg-primary mb-3"><%= doctor.specialization %></span>

            <p><b>Experience:</b> <%= doctor.experience %> years</p>
            <p><b>Consultation Fee:</b> ₹<%= doctor.fees %></p>
            <p><b>Available Days:</b> <%= doctor.availableDays %></p>

            <hr>

            <h5 class="fw-bold">Appointment Guidelines</h5>
            <ul class="text-start mt-3">
              <li>Reach 10–15 minutes before your appointment.</li>
              <li>Carry previous reports or prescriptions if available.</li>
              <li>Explain your symptoms clearly to the doctor.</li>
              <li>Check appointment status from your dashboard.</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="col-lg-7">
        <div class="card shadow border-0 upload-card">
          <div class="card-body p-4">
            <h3 class="fw-bold text-primary mb-3">Appointment Form</h3>

            <% if (error) { %>
              <div class="alert alert-danger"><%= error %></div>
            <% } %>

            <form action="/book-appointment" method="POST" id="appointmentForm">
              <input type="hidden" name="doctorId" value="<%= doctor._id %>">

              <div class="mb-3">
                <label class="form-label">Appointment Date</label>
                <input type="date" name="appointmentDate" id="appointmentDate" class="form-control" required>
              </div>

              <div class="mb-3">
                <label class="form-label">Appointment Time</label>
                <input type="time" name="appointmentTime" id="appointmentTime" class="form-control" required>
              </div>

              <div class="mb-3">
                <label class="form-label">Reason for Appointment</label>
                <textarea name="reason" id="appointmentReason" class="form-control" rows="5" placeholder="Describe your reason for appointment" required></textarea>
              </div>

              <p id="appointmentError" class="client-error"></p>

              <button type="submit" class="btn btn-primary btn-lg w-100">Confirm Appointment</button>
            </form>
          </div>
        </div>

        <div class="alert alert-info mt-4">
          <b>Note:</b> Your appointment status will be marked as Pending until admin approval.
        </div>
      </div>

    </div>
  </div>
</section>

<section class="py-5 bg-light">
  <div class="container text-center">
    <h2 class="fw-bold">Need Emergency Help?</h2>
    <p class="lead">For emergency support, contact the hospital helpline immediately.</p>
    <h4 class="text-danger">📞 +91 9876543210</h4>
  </div>
</section>

<footer class="footer py-5">
  <div class="container">

    <div class="row g-4">

      <div class="col-lg-4">
        <h4 class="fw-bold mb-3">🏥 CareConnect</h4>

        <p>
          Smart Healthcare Platform for online appointments,
          prescription management, doctor discovery and
          seamless patient care.
        </p>
      </div>

      <div class="col-lg-2">
        <h5 class="mb-3">Quick Links</h5>

        <ul class="list-unstyled">
          <li><a href="/" class="footer-link">Home</a></li>
          <li><a href="/doctors" class="footer-link">Doctors</a></li>
          <li><a href="/dashboard" class="footer-link">Dashboard</a></li>
          <li><a href="/appointments" class="footer-link">Appointments</a></li>
        </ul>
      </div>

      <div class="col-lg-3">
        <h5 class="mb-3">Company</h5>

        <ul class="list-unstyled">
          <li><a href="/about" class="footer-link">About Us</a></li>
          <li><a href="/privacy" class="footer-link">Privacy Policy</a></li>
          <li><a href="/terms" class="footer-link">Terms & Conditions</a></li>
        </ul>
      </div>

      <div class="col-lg-3">
        <h5 class="mb-3">Contact</h5>

        <p class="mb-2">📧 support@careconnect.com</p>
        <p class="mb-2">📞 +91 9876543210</p>
        <p>📍 Bhubaneswar, Odisha, India</p>
      </div>

    </div>

    <hr class="my-4">

    <div class="text-center">
      <p class="mb-0">
        © 2026 CareConnect | Smart Healthcare Platform | All Rights Reserved
      </p>
    </div>

  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>
</body>
</html>