<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Doctors</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">CareConnect</a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navMenu">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
        <li class="nav-item"><a class="nav-link active" href="/doctors">Doctors</a></li>
        <li class="nav-item"><a class="nav-link" href="/dashboard">Dashboard</a></li>
        <li class="nav-item"><a class="nav-link" href="/appointments">Appointments</a></li>
        <li class="nav-item"><a class="nav-link" href="/logout">Logout</a></li>
        <li class="nav-item">
  <button id="themeToggle" class="btn btn-sm btn-light ms-lg-3 mt-2 mt-lg-0">
    🌙
  </button>
</li>
      </ul>
    </div>
  </div>
</nav>

<section class="page-header bg-light">
  <div class="container text-center py-5">
    <h1 class="fw-bold text-primary">Available Doctors</h1>
    <p class="lead">Search doctors by name, specialization, experience or fees.</p>
  </div>
</section>

<section class="py-5">
  <div class="container">

    <div class="row justify-content-center mb-4">
      <div class="col-md-7">
        <input
          type="text"
          id="doctorSearch"
          class="form-control form-control-lg"
          placeholder="Search doctor or specialization..."
        >
      </div>
    </div>

    <div class="row g-4" id="doctorList">
      <% if (doctors.length === 0) { %>
        <div class="col-12 text-center">
          <div class="alert alert-info">
            No doctors available right now.
          </div>
        </div>
      <% } %>

      <% doctors.forEach(doctor => { %>
        <div class="col-md-6 col-lg-4 doctor-card">
          <div class="card h-100 shadow doctor-card-ui">
            <div class="card-body text-center">

              <img src="<%= doctor.image %>" class="doctor-img mb-3" alt="Doctor Image">

              <h4 class="fw-bold"><%= doctor.name %></h4>

              <span class="badge bg-primary mb-3">
                <%= doctor.specialization %>
              </span>

              <p><b>Experience:</b> <%= doctor.experience %> years</p>
              <p><b>Consultation Fees:</b> ₹<%= doctor.fees %></p>
              <p><b>Available Days:</b> <%= doctor.availableDays %></p>

              <a href="/book-appointment/<%= doctor._id %>" class="btn btn-primary w-100 mt-2">
                Book Appointment
              </a>

            </div>
          </div>
        </div>
      <% }) %>
    </div>

  </div>
</section>

<footer class="footer py-5">
  <div class="container">

    <div class="row g-4">

      <div class="col-lg-4">
        <h4 class="fw-bold mb-3">🏥 CareConnect</h4>

        <p>
          Smart Healthcare Platform for online appointments,
          prescription management, doctor discovery and
          seamless patient care.
        </p>
      </div>

      <div class="col-lg-2">
        <h5 class="mb-3">Quick Links</h5>

        <ul class="list-unstyled">
          <li><a href="/" class="footer-link">Home</a></li>
          <li><a href="/doctors" class="footer-link">Doctors</a></li>
          <li><a href="/dashboard" class="footer-link">Dashboard</a></li>
          <li><a href="/appointments" class="footer-link">Appointments</a></li>
        </ul>
      </div>

      <div class="col-lg-3">
        <h5 class="mb-3">Company</h5>

        <ul class="list-unstyled">
          <li><a href="/about" class="footer-link">About Us</a></li>
          <li><a href="/privacy" class="footer-link">Privacy Policy</a></li>
          <li><a href="/terms" class="footer-link">Terms & Conditions</a></li>
        </ul>
      </div>

      <div class="col-lg-3">
        <h5 class="mb-3">Contact</h5>

        <p class="mb-2">📧 support@careconnect.com</p>
        <p class="mb-2">📞 +91 9876543210</p>
        <p>📍 Bhubaneswar, Odisha, India</p>
      </div>

    </div>

    <hr class="my-4">

    <div class="text-center">
      <p class="mb-0">
        © 2026 CareConnect | Smart Healthcare Platform | All Rights Reserved
      </p>
    </div>

  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>
</body>
</html>