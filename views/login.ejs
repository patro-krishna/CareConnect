<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Patient Login</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<section class="auth-page">
  <div class="auth-card">
    <h2>Patient Login</h2>
    <p class="auth-subtitle">Login to manage appointments and prescriptions.</p>

    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <form action="/login" method="POST" id="loginForm">
  <input type="email" name="email" id="loginEmail" class="form-control" placeholder="Email Address" required>
  <input type="password" name="password" id="loginPassword" class="form-control" placeholder="Password" required>

  <p id="loginError" class="client-error"></p>

  <button type="submit" class="btn btn-primary w-100">Login</button>
</form>

    <p class="auth-link">Don’t have an account? <a href="/register">Register</a></p>
    <p class="auth-link"><a href="/">Back to Home</a></p>
  </div>
</section>
<script src="/js/script.js"></script>
</body>
</html>