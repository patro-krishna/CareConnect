<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Patient Register</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<section class="auth-page">
  <div class="auth-card">
    <h2>Create Account</h2>
    <p class="auth-subtitle">Register as a patient to book appointments.</p>

    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <form action="/register" method="POST" id="registerForm">
      <input type="text" name="name" id="name" class="form-control" placeholder="Full Name" required>
      <input type="email" name="email" id="email" class="form-control" placeholder="Email Address" required>
      <input type="password" name="password" id="password" class="form-control" placeholder="Password" required>
      <input type="password" name="confirmPassword" id="confirmPassword" class="form-control" placeholder="Confirm Password" required>

      <p id="passwordStrength" class="small-text"></p>
      <p id="clientError" class="client-error"></p>

      <button type="submit" class="btn btn-primary w-100">Register</button>
    </form>

    <p class="auth-link">Already have an account? <a href="/login">Login</a></p>
    <p class="auth-link"><a href="/">Back to Home</a></p>
  </div>
</section>

<script src="/js/script.js"></script>
</body>
</html>