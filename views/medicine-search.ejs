<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Medicine Search</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">CareConnect</a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navMenu">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link" href="/dashboard">Dashboard</a></li>
        <li class="nav-item"><a class="nav-link" href="/doctors">Doctors</a></li>
        <li class="nav-item"><a class="nav-link" href="/appointments">Appointments</a></li>
        <li class="nav-item"><a class="nav-link" href="/prescriptions">Prescriptions</a></li>
        <li class="nav-item"><a class="nav-link active" href="/medicine-search">Medicine API</a></li>
        <li class="nav-item">
          <button id="themeToggle" class="btn btn-sm btn-light ms-lg-3 mt-2 mt-lg-0">🌙</button>
        </li>
        <li class="nav-item"><a class="nav-link" href="/logout">Logout</a></li>
      </ul>
    </div>
  </div>
</nav>

<section class="page-header py-5">
  <div class="container">
    <h1 class="fw-bold text-primary">Medicine Information Search</h1>
    <p class="lead">Search basic medicine information using OpenFDA external API.</p>
  </div>
</section>

<section class="py-5">
  <div class="container">

    <div class="card shadow border-0 mb-4">
      <div class="card-body">
        <form action="/medicine-search" method="POST" class="row g-3">
          <div class="col-md-9">
            <input type="text" name="medicineName" class="form-control" placeholder="Enter medicine name e.g. paracetamol" value="<%= query %>">
          </div>

          <div class="col-md-3">
            <button class="btn btn-primary w-100" type="submit">Search</button>
          </div>
        </form>
      </div>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <% if (medicines) { %>
      <div class="row g-4">
        <% medicines.forEach(item => { %>
          <div class="col-md-6">
            <div class="card shadow border-0 h-100">
              <div class="card-body">
                <h4 class="text-primary">Medicine Details</h4>

                <p><b>Brand Name:</b>
                  <%= item.openfda && item.openfda.brand_name ? item.openfda.brand_name[0] : "N/A" %>
                </p>

                <p><b>Generic Name:</b>
                  <%= item.openfda && item.openfda.generic_name ? item.openfda.generic_name[0] : "N/A" %>
                </p>

                <p><b>Manufacturer:</b>
                  <%= item.openfda && item.openfda.manufacturer_name ? item.openfda.manufacturer_name[0] : "N/A" %>
                </p>

                <p><b>Purpose:</b>
                  <%= item.purpose ? item.purpose[0].substring(0, 180) : "N/A" %>
                </p>

                <p><b>Warnings:</b>
                  <%= item.warnings ? item.warnings[0].substring(0, 220) : "N/A" %>
                </p>

              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

  </div>
</section>

<footer class="footer py-5">
  <div class="container">

    <div class="row g-4">

      <div class="col-lg-4">
        <h4 class="fw-bold mb-3">🏥 CareConnect</h4>

        <p>
          Smart Healthcare Platform for online appointments,
          prescription management, doctor discovery and
          seamless patient care.
        </p>
      </div>

      <div class="col-lg-2">
        <h5 class="mb-3">Quick Links</h5>

        <ul class="list-unstyled">
          <li><a href="/" class="footer-link">Home</a></li>
          <li><a href="/doctors" class="footer-link">Doctors</a></li>
          <li><a href="/dashboard" class="footer-link">Dashboard</a></li>
          <li><a href="/appointments" class="footer-link">Appointments</a></li>
        </ul>
      </div>

      <div class="col-lg-3">
        <h5 class="mb-3">Company</h5>

        <ul class="list-unstyled">
          <li><a href="/about" class="footer-link">About Us</a></li>
          <li><a href="/privacy" class="footer-link">Privacy Policy</a></li>
          <li><a href="/terms" class="footer-link">Terms & Conditions</a></li>
        </ul>
      </div>

      <div class="col-lg-3">
        <h5 class="mb-3">Contact</h5>

        <p class="mb-2">📧 support@careconnect.com</p>
        <p class="mb-2">📞 +91 9876543210</p>
        <p>📍 Bhubaneswar, Odisha, India</p>
      </div>

    </div>

    <hr class="my-4">

    <div class="text-center">
      <p class="mb-0">
        © 2026 CareConnect | Smart Healthcare Platform | All Rights Reserved
      </p>
    </div>

  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>
</body>
</html>